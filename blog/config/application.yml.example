# 数据库配置（复制为 application.yml 后填入真实信息）
spring:
  datasource:
    url: jdbc:mysql://192.168.153.8:3306/myblog?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
    username: root
    password: your_password_here
    driver-class-name: com.mysql.cj.jdbc.Driver

  # JPA 配置
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  # Thymeleaf 配置
  thymeleaf:
    cache: false

# 内置 Tomcat 配置（与 resume 项目同机部署时使用 8081，避免与 Tomcat 8080 冲突）
server:
  address: 0.0.0.0
  port: 8081
