server:
  port: 9002

spring:
  application:
    name: blog-admin

eureka:
  instance:
    prefer-ip-address: true
    ip-address: 127.0.0.1
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/
    fetch-registry: true
    register-with-eureka: true

logging:
  level:
    com.blogadmin: DEBUG
    org.springframework.web: DEBUG
